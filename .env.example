# Copy to .env.local and fill in your own values (never commit .env.local)

# Neon Postgres
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Supabase (Auth only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Auth redirects (email confirm → onboarding). Required for production:
# NEXT_PUBLIC_SITE_URL=https://mctc-portal.vercel.app
# Local dev: omit or set explicitly (dev server defaults to http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
